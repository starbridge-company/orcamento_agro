# ============================================================
# .env ÚNICO do projeto (backend + frontend).
# Copie para .env: copy .env.example .env
# O backend lê todas as variáveis. O Vite expõe ao navegador
# APENAS as que começam com VITE_.
# ============================================================

# Banco Postgres (usado pelas migrations: npm run migrate).
# As migrations criam todos os objetos no schema `agro` (não no public).
# Ex.: postgresql://usuario:senha@localhost:5432/mvp_agro
DATABASE_URL=

# ============================================================
# Autenticação (login seguro: JWT + argon2 + refresh rotativo)
# ============================================================
# OBRIGATÓRIO. Segredo HMAC que assina os access tokens (HS256). Use >= 32
# caracteres aleatórios. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Opcionais (têm padrões sensatos no código):
# JWT_ISSUER=orcamento-agro
# JWT_AUDIENCE=orcamento-agro-web
# AUTH_ACCESS_TTL_SEC=900                # validade do access token (15 min)
# AUTH_REFRESH_TTL_SEC=43200             # sessão normal (12 h)
# AUTH_REFRESH_REMEMBER_TTL_SEC=2592000  # sessão "lembrar de mim" (30 dias)
# AUTH_COOKIE_SECURE=true                # padrão: true fora de dev (exige HTTPS)
# AUTH_MAX_LOGIN_ATTEMPTS=5              # tentativas antes de bloquear a conta
# AUTH_LOCKOUT_MINUTES=15               # duração do bloqueio
# AUTH_ALLOW_REGISTRATION=false         # liga /api/auth/register (self-registration)
# ARGON_MEMORY_KIB=19456                 # custo de memória do argon2id (19 MiB)
# ARGON_TIME_COST=2
# ARGON_PARALLELISM=1

# ============================================================
# Pipeline de cotação (migração do fluxo n8n para código)
# ============================================================
# O envio da cotação roda um pipeline assíncrono que descobre fornecedores
# (Google Places -> Perplexity -> cidades vizinhas), verifica WhatsApp e
# dispara a mensagem via Evolution API, encerrando com e-mail ao comprador.
# Sem estas chaves o servidor SOBE normalmente; o job é que marca a cotação
# como 'failed' se precisar de um provider não configurado.

# OpenAI: classificação de grupo de insumos + listagem de cidades vizinhas.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.1

# Google Maps: Places (Text Search + Details) e Geocoding.
GOOGLE_MAPS_API_KEY=

# Perplexity (fonte alternativa de fornecedores).
PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar-pro

# Evolution API (WhatsApp): mesma instância verifica número e envia mensagem.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=Starbridge

# SMTP (nodemailer) para os e-mails ao comprador.
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=false          # true => porta 465 (TLS implícito)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# SMTP_FROM_NAME=Agente Comprador

# Tunáveis do pipeline (opcionais; padrões sensatos no código):
# SUPPLIERS_TARGET=8              # alvo de fornecedores por cotação
# SEARCH_MAX_RADIUS_KM=100        # raio máximo ao expandir p/ cidades vizinhas
# DISPATCH_DELAY_MS=1500          # intervalo entre envios de WhatsApp
# PIPELINE_HTTP_TIMEOUT_MS=30000  # timeout por chamada externa

# MODO DE TESTE CONTROLADO: se preenchido, TODO envio de WhatsApp vai para este
# número (formato 55DDDNÚMERO) em vez do fornecedor real. DEIXE VAZIO EM PRODUÇÃO.
# DISPATCH_TEST_RECIPIENT=
