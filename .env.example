# ============================================================
# .env ÚNICO do projeto (backend + frontend).
# Copie para .env: copy .env.example .env
# O backend lê todas as variáveis. O Vite expõe ao navegador
# APENAS as que começam com VITE_.
# ============================================================

# Webhook que recebe a cotação para contatar os fornecedores. Configurável.
WEBHOOK_URL=https://n8n-gw8k8gks84k0cwcgwo4ws884.app5.w8hub.com.br/webhook/fbe013a0-9e52-43e3-9671-5d52f63f60da

# Tempo máximo (ms) de espera pela resposta do webhook.
WEBHOOK_TIMEOUT_MS=15000

# Banco Postgres (usado pelas migrations: npm run migrate).
# As migrations criam todos os objetos no schema `agro` (não no public).
# Ex.: postgresql://usuario:senha@localhost:5432/mvp_agro
DATABASE_URL=

# ============================================================
# Autenticação (login seguro: JWT + argon2 + refresh rotativo)
# ============================================================
# OBRIGATÓRIO. Segredo HMAC que assina os access tokens (HS256). Use >= 32
# caracteres aleatórios. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Opcionais (têm padrões sensatos no código):
# JWT_ISSUER=orcamento-agro
# JWT_AUDIENCE=orcamento-agro-web
# AUTH_ACCESS_TTL_SEC=900                # validade do access token (15 min)
# AUTH_REFRESH_TTL_SEC=43200             # sessão normal (12 h)
# AUTH_REFRESH_REMEMBER_TTL_SEC=2592000  # sessão "lembrar de mim" (30 dias)
# AUTH_COOKIE_SECURE=true                # padrão: true fora de dev (exige HTTPS)
# AUTH_MAX_LOGIN_ATTEMPTS=5              # tentativas antes de bloquear a conta
# AUTH_LOCKOUT_MINUTES=15               # duração do bloqueio
# AUTH_ALLOW_REGISTRATION=false         # liga /api/auth/register (self-registration)
# ARGON_MEMORY_KIB=19456                 # custo de memória do argon2id (19 MiB)
# ARGON_TIME_COST=2
# ARGON_PARALLELISM=1
