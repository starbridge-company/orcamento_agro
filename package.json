{
  "name": "mvp-agro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cotação de insumos do agronegócio — frontend (React) e backend (Express) num projeto único, mesmo node_modules, mesma porta.",
  "scripts": {
    "dev": "node dev.mjs",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/server/db/migrate.ts up",
    "migrate:down": "tsx src/server/db/migrate.ts down",
    "migrate:status": "tsx src/server/db/migrate.ts status"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
